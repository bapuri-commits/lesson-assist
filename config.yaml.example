# lesson-assist v2 설정 파일
# 이 파일을 config.yaml로 복사해서 사용하세요.

# school_sync 연동 (school_sync가 생성한 가공 데이터만 참조)
school_sync:
  root: "C:\\path\\to\\school_sync"
  context_dir: "output/context"       # 과목별 학습 컨텍스트 (school_sync가 생성)
  downloads_dir: "output/downloads"   # 수업자료 PDF/PPT 원본

# 다글로 입력
daglo:
  input_dir: "input/daglo"

# NotebookLM 패키징
notebooklm:
  output_dir: "output/notebooklm"
  auto_open: true               # pack 완료 시 폴더 자동 열기
  guide_extras: {}              # 과목별 추가 가이드 (courses에서 설정 권장)

# NotebookLM 결과 입력
from_notebooklm:
  input_dir: "input/from_notebooklm"

# Obsidian
obsidian:
  vault_path: "G:\\CS_Study\\The Record"
  lecture_dir: "3_Areas/Lectures"
  daily_dir: "1_Daily"

# 과목별 설정 (선택)
# courses:
#   자료구조:                          # daglo 폴더명
#     sync_name: "자료구조"            # school_sync 과목명 (다르면 매핑)
#     guide_extra: ""
#   DB:                                # daglo 폴더명이 "DB"지만
#     sync_name: "데이터베이스"        # school_sync에서는 "데이터베이스"
#     guide_extra: ""
#   머신러닝:
#     guide_extra: "수식은 LaTeX 표기로 정리해주세요."
